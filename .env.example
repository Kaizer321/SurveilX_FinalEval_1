# ─── PostgreSQL (Neon Cloud) ───────────────────────────────────────────────────
# Format: postgresql://user:password@host/dbname?sslmode=require
SURVEILX_DB_URL=

# ─── Cloudinary (frame/image storage) ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- ChromaDB (Railway) ---
# The URL of your Railway-hosted Chroma instance (e.g., https://chroma-production.up.railway.app)
CHROMA_HOST=
CHROMA_PORT=
CHROMA_TOKEN=

# ─── Default Credentials ──────────────────────────────────────────────────────
# These are used by the system to seed the initial admin and user accounts on first run.
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_USER_PASSWORD=user123

# ─── Optional Configuration ──────────────────────────────────────────────────
# LOG_LEVEL=INFO
# VIOLENCE_CKPT_PATH=models/cnn_lstm_fusion.pth
